module countPC(pcin, reset, clock, pcout);
	input pcin, reset, clock;
	output pcout;
	
	// inicializa o pcin com 0 quando reset estiver ativo
	initial 
	begin
	
		if(reset)
		begin
			pcin = 0;
		end
		
	end
	
	// registrador intermediario para a chamda do somador
	wire cout, overflow;
	
	// bloco always para atribuir pcout = pcin + 4
	always @(posedge clock)
	begin
		// module somador32bits(a, b, cin, s, cout, overflow);
		somador32bits adder(pcin, {29'b0, 3'b100}, 0, pcout, cout, overflow);
	end	

endmodule