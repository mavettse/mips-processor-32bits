	/*		
				---- INPUTS ----
			reset				-> SW[17] 
			display_sel		-> SW[2:0] 
			
				---- OUTPUTS ----
			valor_display	-> HEX7 - HEX0
			overflow			-> LEDR[0]
			zero				-> LEDG[0]
	*/

pratica6_top(SW, CLOCK_50, HEX0, HEX1, HEX2, HEX3, HEX4, HEX5, HEX6, HEX7, LEDR, LEDG);
	input CLOCK_50;
	input [17:0] SW;
	output [6:0] HEX0, HEX1, HEX2, HEX3, HEX4, HEX5, HEX6, HEX7;
	output [17:0] LEDR;
	output [7:0] LEDG;
	
	// FIOS INTERNOS
	wire clock, reset;
	wire [2:0] display_sel;
	
	assign clock = CLOCK_50;
	assign reset = SW[17];
	assign display_sel = SW[2:0];
	
	wire [31:0] pc_valor;
	wire [31:0] instrucao_valor;
	wire [31:0] ULA_valor;
	wire zero_flag;
	wire overflow_flag
	
	// INSTANCIACAO 
	processador processador_placa(
		.clock(clock),
		.reset(reset),
		.pcout_out(pc_valor),
		.instruction_out(instrucao_valor),
		.alu_result_out(ULA_valor),
		.zero_out(zero_flag),
		.overflow_out(overflow_flag)
	);
	
	// LOGICA SAIDA
	assign LEDR = {17'b00000000000000000, zero_flag};
	assign LEDG = {7'b0000000, overflow_flag};
	
	reg[31:0] valor_display;
	
	always @(*)
	begin
		case(display_sel)
			3'b000: valor_display = pc_valor;
			3'b001: valor_display = instrucao_valor;
			3'b010: valor_display = ULA_valor;
			default: valor_display = 32'b0;
		endcase
	end
	
	hex_display disp0 (valor_display[3:0],   HEX0);
	hex_display disp1 (valor_display[7:4],   HEX1);
	hex_display disp2 (valor_display[11:8],  HEX2);
	hex_display disp3 (valor_display[15:12], HEX3);
	hex_display disp4 (valor_display[19:16], HEX4);
	hex_display disp5 (valor_display[23:20], HEX5);
	hex_display disp6 (valor_display[27:24], HEX6);
	hex_display disp7 (valor_display[31:28], HEX7);

endmodule