module processador;

	wire pcin, reset, CLOCK_50, pcout, readAddress, regWrite, overflow;
	wire [31:0] instruction, a, b, s;
	input [2:0] ULAop;
	
	// countPC(pcin, reset, CLOCK_50, pcout);
	countPC pc(pcin, reset, CLOCK_50, pcout);
	// memoriaInstrucao(readAddress, instruction);
	memoriaInstrucao memIns(readAddress, instruction);

	assign pcout = readAddress; 
	
	// bancoRegistradores  (Read1					, Read2				  , WriteReg	, WriteData, RegWrite, Data1, Data2, clock);
	bancoRegistradores bReg(instruction[25:21], instruction[20:16], instruction[15:11], s , RegWrite, a, b, CLOCK_50);
	
	// ULA32bits (a, b, ULAop, zero, s, overflow);
	ULA32bits ula(a, b, ULAop, zero, s, overflow);

	

endmodule