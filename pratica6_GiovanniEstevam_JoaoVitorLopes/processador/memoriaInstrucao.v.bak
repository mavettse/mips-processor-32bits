module memoriaInstrucao(readAddress, instruction);
	input readAddress;
	output [31:0] instruction;
	
	// cria um registrador para acessar o conteudo do endereco
	reg [31:0] registrador;
	
	// pega o valor contido no endereco do PC e atribui à instrucao
	assign instruction = registrador[readAddress];

endmodule